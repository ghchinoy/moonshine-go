
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/

# Native libmoonshine build output (see scripts/build-libmoonshine.sh);
# built locally from a moonshine checkout, not vendored/committed.
/.moonshine/

# Go build artifacts
/bin/
/dist/
*.test
*.out
coverage.txt

# Downloaded model assets, in case `moonshine setup`/`transcribe`/`live` is
# ever pointed at a project-local --model-dir instead of the default cache.
/.moonshine-models/

# Credentials that should never end up in a public repo (e.g. a GCP service
# account key used for gs:// transcription input).
*-key.json
service-account*.json
credentials.json
.env

# OS / editor cruft
.DS_Store

# Local editor/agent-tool state, not project config
.serena/

# Internal vision/landscape touchstone docs -- not part of the public repo
/docs/vision/

# Stray tts default output if run from the repo root without -o
/out.wav
*.swp
*.swo
*~
.idea/
.vscode/
